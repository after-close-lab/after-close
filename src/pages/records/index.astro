---
import { getCollection } from 'astro:content';
import RecordCard from '../../components/RecordCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const records = (await getCollection('records'))
  .sort((a, b) => b.data.recorded_at.getTime() - a.data.recorded_at.getTime());
const authors = [...new Set(records.map((record) => record.data.author))].sort();
const markets = [...new Set(records.map((record) => record.data.market))].sort();
const effects = [...new Set(records.map((record) => record.data.position_effect))].sort();
---

<BaseLayout title="决策档案" description="按成员、市场、标的、动作和策略浏览交易决策记录。">
  <section class="page-head shell">
    <p class="eyebrow">DECISION RECORDS</p>
    <h1>决策档案</h1>
    <p>每条记录保存一个时间点的真实决策。默认按记录时间倒序，不提供收益排序。</p>
  </section>

  <section class="shell archive-layout">
    <form class="filters" data-record-filters>
      <label>
        成员
        <select name="author">
          <option value="">全部</option>
          {authors.map((author) => <option value={author}>{author}</option>)}
        </select>
      </label>
      <label>
        市场
        <select name="market">
          <option value="">全部</option>
          {markets.map((market) => <option value={market}>{market}</option>)}
        </select>
      </label>
      <label>
        动作
        <select name="effect">
          <option value="">全部</option>
          {effects.map((effect) => <option value={effect}>{effect}</option>)}
        </select>
      </label>
      <label>
        标的或策略
        <input name="query" type="search" placeholder="DEMO / experimental" autocomplete="off" />
      </label>
      <button type="reset">重置筛选</button>
    </form>
    <div>
      <p class="result-count" aria-live="polite" data-result-count>共 {records.length} 条记录</p>
      <div class="archive-list" data-record-list>
        {records.map((record) => <RecordCard record={record} />)}
      </div>
      <div class="empty-state" data-filter-empty hidden>没有符合当前筛选条件的记录。</div>
    </div>
  </section>

  <script>
    const form = document.querySelector('[data-record-filters]');
    const cards = [...document.querySelectorAll('[data-record-card]')];
    const count = document.querySelector('[data-result-count]');
    const empty = document.querySelector('[data-filter-empty]');

    const applyFilters = () => {
      if (!(form instanceof HTMLFormElement)) return;
      const values = new FormData(form);
      const author = String(values.get('author') ?? '');
      const market = String(values.get('market') ?? '');
      const effect = String(values.get('effect') ?? '');
      const query = String(values.get('query') ?? '').trim().toLowerCase();
      let visible = 0;

      for (const card of cards) {
        if (!(card instanceof HTMLElement)) continue;
        const matches = (!author || card.dataset.author === author)
          && (!market || card.dataset.market === market)
          && (!effect || card.dataset.effect === effect)
          && (!query || `${card.dataset.symbol} ${card.dataset.strategies}`.includes(query));
        card.hidden = !matches;
        if (matches) visible += 1;
      }

      if (count) count.textContent = `共 ${visible} 条记录`;
      if (empty instanceof HTMLElement) empty.hidden = visible !== 0;
    };

    form?.addEventListener('input', applyFilters);
    form?.addEventListener('reset', () => requestAnimationFrame(applyFilters));
  </script>
</BaseLayout>
